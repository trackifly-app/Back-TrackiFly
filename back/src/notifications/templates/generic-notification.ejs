<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — TrackiFly</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f6f9;font-family:'Segoe UI',Roboto,Arial,sans-serif;">
  <%
    // Paleta de colores TrackiFly (Naranja Moderno)
    const trackiOrange = '#FF6B00';
    const colorMap = {
      alert:          { gradient: 'linear-gradient(135deg,#ef4444 0%,#dc2626 100%)', accent: '#ef4444' },
      warning:        { gradient: 'linear-gradient(135deg,#f59e0b 0%,#d97706 100%)', accent: '#f59e0b' },
      success:        { gradient: 'linear-gradient(135deg,#FF9D00 0%,#FF4D00 100%)', accent: '#FF6B00' }, 
      info:           { gradient: 'linear-gradient(135deg,#FF6B00 0%,#FF4D00 100%)', accent: '#FF6B00' },
      otp:            { gradient: 'linear-gradient(135deg,#FF6B00 0%,#FF4D00 100%)', accent: '#FF6B00' },
    };
    const colors = colorMap[type] || colorMap.info;
  %>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f6f9;padding:40px 0;">
    <tr>
      <td align="center">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.08);">
          
          <!-- Header -->
          <tr>
            <td style="background:<%= colors.gradient %>;padding:32px 40px;text-align:center;">
              <img
                src="https://res.cloudinary.com/demo/image/upload/v1/trackilfy-logo-placeholder.png"
                alt="TrackiFly"
                width="160"
                style="display:inline-block;"
              />
              <h1 style="color:#ffffff;font-size:22px;margin:16px 0 0;font-weight:600;letter-spacing:-0.5px;">
                <%= title %>
              </h1>
            </td>
          </tr>

          <!-- Cuerpo -->
          <tr>
            <td style="padding:40px;">
              <p style="color:#374151;font-size:16px;line-height:1.7;margin:0 0 24px;">
                <%= message %>
              </p>

              <% if (typeof actionUrl !== 'undefined' && actionUrl) { %>
                <!-- Botón de acción -->
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                  <tr>
                    <td align="center" style="padding:8px 0 24px;">
                      <a
                        href="<%= actionUrl %>"
                        target="_blank"
                        style="display:inline-block;background-color:<%= colors.accent %>;color:#ffffff;text-decoration:none;font-size:16px;font-weight:600;padding:14px 32px;border-radius:8px;"
                      >
                        <%= typeof actionLabel !== 'undefined' && actionLabel ? actionLabel : 'Ver más' %>
                      </a>
                    </td>
                  </tr>
                </table>
              <% } %>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color:#f9fafb;padding:24px 40px;border-top:1px solid #e5e7eb;">
              <p style="color:#9ca3af;font-size:12px;line-height:1.5;margin:0;text-align:center;">
                © <%= year %> TrackiFly. Todos los derechos reservados.<br/>
                Este es un correo automático, por favor no respondas a este mensaje.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
